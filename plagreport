        ax4.barh(pat_labels[::-1], pat_counts[::-1], color=AMBER, edgecolor=DARK, linewidth=0.5)
        for i, v in enumerate(pat_counts[::-1]):
            ax4.text(v + 1, i, str(v), va="center", color=WHITE, fontsize=8)
    style_ax(ax4, "Top Repeated Patterns")

    # 5. Heatmap of top 20x25 similarity matrix
    ax5 = fig.add_subplot(gridspec[2, :])
    top_docs = sorted(scanner.doc_scores.items(), key=lambda x: x[1], reverse=True)[:25]
    top_ids  = [d for d, _ in top_docs]
    n = len(top_ids)
    matrix = np.zeros((n, n))
    score_map = {d: s for d, s in top_docs}
    pair_map = {(r.doc_a, r.doc_b): r.similarity_pct for r in scanner.results}
    pair_map.update({(r.doc_b, r.doc_a): r.similarity_pct for r in scanner.results})
    for i, di in enumerate(top_ids):
        for j, dj in enumerate(top_ids):
            if i == j:
                matrix[i, j] = 100
            else:
                matrix[i, j] = pair_map.get((di, dj), 0)

    im = ax5.imshow(matrix, cmap="RdYlGn_r", vmin=0, vmax=100, aspect="auto")
    ax5.set_xticks(range(n))
    ax5.set_yticks(range(n))
    ax5.set_xticklabels([t.replace("STU-", "") for t in top_ids], rotation=45,
                         color=GREY, fontsize=7)
    ax5.set_yticklabels([t.replace("STU-", "") for t in top_ids], color=GREY, fontsize=7)
    cbar = fig.colorbar(im, ax=ax5, fraction=0.02, pad=0.01)
    cbar.ax.yaxis.set_tick_params(color=GREY, labelcolor=GREY)
    cbar.set_label("Similarity %", color=GREY, fontsize=9)
    style_ax(ax5, "Pairwise Similarity Heatmap — Top 25 Flagged Submissions")

    plt.savefig(output_path, dpi=130, bbox_inches="tight",
                facecolor=DARK, edgecolor="none")
    plt.close()


