def fingerprint(text: str, k: int = 8) -> set:
    """Shingling fingerprint for fast similarity estimate."""
    words = text.lower().split()
    return {hashlib.md5(" ".join(words[i:i+k]).encode()).hexdigest()
            for i in range(max(1, len(words) - k + 1))}


def jaccard_similarity(a: set, b: set) -> float:
    if not a or not b:
        return 0.0
    return len(a & b) / len(a | b)


def sequence_similarity(a: str, b: str) -> float:
    return difflib.SequenceMatcher(None, a[:800], b[:800]).ratio()


@dataclass
class MatchResult:
    doc_a: str
    doc_b: str
    similarity_pct: float
    matched_positions: List[Tuple[int, int, str]]   # (pos_a, pos_b, matched_text)
    method: str = "KMP+Jaccard"


@dataclass
class DocumentResult:
    doc_id: str
    similarity: float
    risk: str
    matches: List[MatchResult] = field(default_factory=list)


