                ratio = random.uniform(0.70, 1.0)
            elif r < 0.30:
                ratio = random.uniform(0.40, 0.69)
            else:
                ratio = random.uniform(0.0, 0.30)
            doc_id = f"STU-{i:03d}"
            documents[doc_id] = generate_document(i, ratio, BASE_DEFS)
            progress.advance(task)

    console.print(f"  [green]✓[/green] Generated [bold]{TOTAL_DOCS}[/bold] student documents\n")

