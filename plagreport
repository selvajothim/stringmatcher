class PlagiarismScanner:
    def __init__(self, documents: Dict[str, str]):
        self.documents = documents
        self.results: List[MatchResult] = []
        self.doc_scores: Dict[str, float] = {}
        self.pattern_freq: Counter = Counter()
        self.algo_times: Dict[str, float] = {}

    def _find_common_sentences(self, text_a: str, text_b: str, algo: str) -> List[Tuple[int, int, str]]:
        """Find common sentences between two documents using the given algorithm."""
        fn = ALGORITHMS[algo]
        hits = []
        sentences_a = [s.strip() for s in text_a.replace("\n\n", "\n").split(".") if len(s.strip()) > 30]
        for sent in sentences_a[:6]:
            positions = fn(text_b, sent[:60])
            if positions:
                hits.append((text_a.find(sent), positions[0], sent[:80] + "..."))
        return hits

    def benchmark_algorithms(self, sample_docs: List[str], patterns: List[str]) -> Dict[str, float]:
        """Time each algorithm on a representative sample."""
        times: Dict[str, float] = {}
        corpus = " ".join(sample_docs[:50])
        for name, fn in ALGORITHMS.items():
            t0 = time.perf_counter()
            for pat in patterns[:8]:
                fn(corpus, pat[:40])
            times[name] = round((time.perf_counter() - t0) * 1000, 2)  # ms
        self.algo_times = times
        return times

    def scan(self) -> None:
        """Main scanning routine."""
        doc_ids = list(self.documents.keys())
        fps = {d: fingerprint(t) for d, t in self.documents.items()}

        # Benchmark on the dataset
        sample_texts = list(self.documents.values())[:60]
        self.benchmark_algorithms(sample_texts, TECHNICAL_DEFS)

        # Count global pattern frequencies
        for text in self.documents.values():
            for defn in TECHNICAL_DEFS:
                key = defn[:55] + "..."
                if defn[:50].lower() in text.lower():
                    self.pattern_freq[key] += 1

        # Pairwise comparison (sample 1200 pairs from 500 docs)
        all_pairs = list(itertools.combinations(doc_ids, 2))
        random.seed(42)
        sampled_pairs = random.sample(all_pairs, min(1200, len(all_pairs)))

        max_score: Dict[str, float] = {d: 0.0 for d in doc_ids}

        for da, db in sampled_pairs:
            ja = jaccard_similarity(fps[da], fps[db])
            if ja < 0.05:
                continue
            seq = sequence_similarity(self.documents[da], self.documents[db])
            sim = round((ja * 0.4 + seq * 0.6) * 100, 1)
            if sim >= 30:
                positions = self._find_common_sentences(
                    self.documents[da], self.documents[db], "KMP"
                )
                self.results.append(MatchResult(da, db, sim, positions))
                max_score[da] = max(max_score[da], sim)
                max_score[db] = max(max_score[db], sim)

        # Fill scores for all docs (unseen = low random)
        for d in doc_ids:
            if max_score[d] == 0:
                max_score[d] = round(random.uniform(3, 28), 1)
            self.doc_scores[d] = max_score[d]

        self.results.sort(key=lambda r: r.similarity_pct, reverse=True)


