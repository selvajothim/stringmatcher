def kmp_search(text: str, pattern: str) -> List[int]:
    """Knuth-Morris-Pratt algorithm — O(n + m)."""
    if not pattern or not text:
        return []
    n, m = len(text), len(pattern)
    lps = [0] * m
    length = 0
    i = 1
    while i < m:
        if pattern[i] == pattern[length]:
            length += 1
            lps[i] = length
            i += 1
        elif length:
            length = lps[length - 1]
        else:
            lps[i] = 0
            i += 1
    positions = []
    i = j = 0
    while i < n:
        if pattern[j] == text[i]:
            i += 1
            j += 1
        if j == m:
            positions.append(i - j)
            j = lps[j - 1]
        elif i < n and pattern[j] != text[i]:
            j = lps[j - 1] if j else 0
            if not j:
                i += 1
    return positions


def rabin_karp_search(text: str, pattern: str, base: int = 256, mod: int = 101) -> List[int]:
    """Rabin-Karp rolling hash — avg O(n + m)."""
    n, m = len(text), len(pattern)
    if m > n or not pattern:
        return []
    h = pow(base, m - 1, mod)
    p_hash = t_hash = 0
    for i in range(m):
        p_hash = (base * p_hash + ord(pattern[i])) % mod
        t_hash = (base * t_hash + ord(text[i])) % mod
    positions = []
    for i in range(n - m + 1):
        if p_hash == t_hash and text[i:i + m] == pattern:
            positions.append(i)
        if i < n - m:
            t_hash = (base * (t_hash - ord(text[i]) * h) + ord(text[i + m])) % mod
    return positions


def boyer_moore_search(text: str, pattern: str) -> List[int]:
    """Boyer-Moore bad-character heuristic — O(n/m) best case."""
    n, m = len(text), len(pattern)
    if not pattern or m > n:
        return []
    bad_char: Dict[str, int] = {c: i for i, c in enumerate(pattern)}
    positions = []
    s = 0
    while s <= n - m:
        j = m - 1
        while j >= 0 and pattern[j] == text[s + j]:
            j -= 1
        if j < 0:
            positions.append(s)
            s += (m - bad_char.get(text[s + m], -1)) if s + m < n else 1
        else:
            bc = bad_char.get(text[s + j], -1)
            s += max(1, j - bc)
    return positions


def naive_search(text: str, pattern: str) -> List[int]:
    """Brute-force O(n×m) baseline."""
    n, m = len(text), len(pattern)
    return [i for i in range(n - m + 1) if text[i:i + m] == pattern]


ALGORITHMS = {
    "KMP": kmp_search,
    "Rabin-Karp": rabin_karp_search,
    "Boyer-Moore": boyer_moore_search,
    "Naive Search": naive_search,
}


