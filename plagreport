def generate_document(doc_id: int, plagiarism_ratio: float = 0.0,
                       source_defs: Optional[List[str]] = None) -> str:
    """Generate a synthetic student document with controllable plagiarism ratio."""
    random.seed(doc_id * 7 + 13)
    intro = random.choice(UNIQUE_INTROS) + f" the topic assigned in submission {doc_id}."
    conclusion = random.choice(UNIQUE_CONCLUSIONS) + " the concepts covered are essential to the field."

    num_defs = random.randint(3, 6)
    defs_to_use: List[str] = []
    n_copied = int(num_defs * plagiarism_ratio)

    if n_copied > 0 and source_defs:
        defs_to_use.extend(random.sample(source_defs, min(n_copied, len(source_defs))))
    for _ in range(num_defs - len(defs_to_use)):
        base = random.choice(TECHNICAL_DEFS)
        if plagiarism_ratio < 0.3:
            words = base.split()
            random.shuffle(words[:4])
            base = " ".join(words)
        defs_to_use.append(base)

    fillers = [random.choice(FILLER) for _ in range(random.randint(2, 4))]
    paragraphs = [intro] + defs_to_use + fillers + [conclusion]
    random.shuffle(paragraphs[1:-1])
    return "\n\n".join(paragraphs)


